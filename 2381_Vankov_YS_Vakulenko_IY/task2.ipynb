      "source": [
        "C = mid[k // 2 - 1]\n",
        "u = np.round((mid - C) / h).astype(int)\n",
        "n_i = int_df[\"m_i\"].values\n",
        "t1 = pd.DataFrame({\n",
        "    \"i\": np.arange(1, k+1),\n",
        "    \"x_i\": mid,\n",
        "    \"n_i\": n_i,\n",
        "    \"u_i\": u,\n",
        "    \"n_i*u_i\": n_i * u,\n",
        "    \"n_i*u_i^2\": n_i * (u**2),\n",
